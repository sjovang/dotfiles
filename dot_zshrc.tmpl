{{ if eq .chezmoi.os "darwin" -}}

{{- if lookPath "starship" }}
eval "$(starship init zsh)"
{{ end -}}

{{- if lookPath "direnv" }}
eval "$(direnv hook zsh)"
{{ end -}}

{{- if lookPath "eza" }}
alias ls="eza"
{{ end -}}

{{- if lookPath "fzf" }}
source <(fzf --zsh)
{{ end -}}

{{- if lookPath "nvim" }}
alias vi="nvim"
{{ end -}}

{{- if lookPath "pre-commit" }}
{{- if lookPath "yq" }}
precommit-merge-config() {
  local global="$HOME/.config/.pre-commit-config.yaml"
  local local_cfg=".pre-commit-config.local.yaml"
  local out=".pre-commit-config.yaml"

  if [[ -f "$local_cfg" ]]; then
    yq eval-all '. as $item ireduce ({}; . * $item)' "$global" "$local_cfg" > "$out"
  else
    cp "$global" "$out"
  fi
}
{{ end -}}
{{ end -}}

{{- if .wireguard.enabled }}
{{- if lookPath "wg-quick" }}
wireguard() {
  case "$1" in
    up)
      sudo wg-quick up wg0
      ;;
    down)
      sudo wg-quick down wg0
      ;;
    status)
      sudo wg show
      ;;
    *)
      echo "Usage: wireguard {up|down|status}"
      ;;
  esac
}
{{ end -}}
{{- end }}

ssh-add --apple-load-keychain -q

{{- if stat "/opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh" }}
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
{{- end }}

{{- if stat "/opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" }}
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
{{- end }}
{{- end }}
