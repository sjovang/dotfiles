{{- if lookPath "brew" -}}
#!/bin/bash

export HOMEBREW_NO_ENV_HINTS=1

# Setup thirdparty taps for terraform
brew tap "terraform-linters/tap"
brew trust terraform-linters/tap

# Install packages
brew bundle --file=/dev/stdin <<EOF
{{ if eq .chezmoi.os "darwin" -}}
brew "azure-cli"
brew "container"
brew "direnv"
brew "eza"
brew "fzf"
brew "gh"
brew "git-delta"
brew "gitleaks"
brew "htop"
brew "mise"
brew "neovim"
brew "npm"
brew "pre-commit"
brew "pwgen"
brew "starship"
brew "terraform-docs"
brew "tenv"
cask "tflint"
brew "tree"
brew "uv"
brew "yq"
brew "zsh-autosuggestions"
brew "zsh-syntax-highlighting"
cask "bitwarden"
cask "copilot-cli"
cask "discord"
cask "font-monaspace"
cask "font-monaspace-var"
cask "ghostty"
cask "github-copilot-app"
{{- if and (hasKey . "microsoft_tools") .microsoft_tools }}
cask "onedrive"
cask "microsoft-teams"
{{- end }}
cask "visual-studio-code"
{{- if .wireguard.enabled }}
brew "wireguard-tools"
{{- end }}
{{ end -}}
EOF

brew completions link
{{ end -}}
